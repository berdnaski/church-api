generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChurchRole {
  OWNER
  PASTOR
  ADMIN
  LEADER
  MEMBER
}

model Church {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  isActive    Boolean   @default(true)
  address     String?
  phone       String?
  email       String?
  description String?
  logoUrl     String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users User[]
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      ChurchRole @default(MEMBER)
  isActive  Boolean    @default(true)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  churchId String
  church   Church @relation(fields: [churchId], references: [id])
}
