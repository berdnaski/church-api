generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChurchRole {
  OWNER
  PASTOR
  ADMIN
  LEADER
  MEMBER
}

model Church {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  isActive    Boolean   @default(true)
  address     String?
  phone       String?
  email       String?
  description String?
  logoUrl     String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users User[]

  departments Department[]
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  STABLE_UNION
}

enum BaptismStatus {
  NOT_BAPTIZED
  BAPTIZED
  WAITING
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      ChurchRole @default(MEMBER)
  isActive  Boolean    @default(true)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  churchId String
  church   Church @relation(fields: [churchId], references: [id])

  passwordResets PasswordReset[]
  profile        UserProfile?

  departmentMembers DepartmentMember[]
}

model UserProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone         String?
  birthDate     DateTime?
  gender        Gender?
  maritalStatus MaritalStatus? @default(SINGLE)
  cpf           String?        @unique
  photoUrl      String?

  baptismStatus BaptismStatus @default(NOT_BAPTIZED)
  baptismDate   DateTime?
  memberSince   DateTime?     @default(now())

  zipCode      String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

enum DepartmentRole {
  LEADER
  MEMBER
}

model Department {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt

  churchId String
  church   Church @relation(fields: [churchId], references: [id])

  departmentMembers DepartmentMember[]

  @@map("departments")
}

model DepartmentMember {
  id           String         @id @default(uuid())
  departmentId String
  userId       String
  role         DepartmentRole @default(MEMBER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("department_members")
}
